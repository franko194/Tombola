# Backend persistence for shared use across PCs.
# Use a managed PostgreSQL connection string from Neon, Supabase, or Vercel Postgres.
DATABASE_URL=postgresql://usuario:password@host:5432/tombola?sslmode=require

# Optional when the API is consumed from another domain.
# The Vercel app calls /api on the same domain, so this is usually not required.
ALLOWED_ORIGINS=https://tombola-rust.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Optional frontend mode.
# Leave empty to use the backend API. Set to local only for browser-only demo mode.
# VITE_DATA_MODE=local

# Optional generative AI for team balance explanations.
# Without this key, the app uses a local deterministic explanation.
OPENAI_API_KEY=sk-proj_xxx
OPENAI_MODEL=gpt-4.1-mini
